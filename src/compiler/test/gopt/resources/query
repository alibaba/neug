CREATE NODE TABLE person(id INT64, name STRING, age INT64, PRIMARY KEY(id));
SCHEMA test/gopt/resources/person_schema.yaml test/gopt/resources/person_stats.json 
CREATE REL TABLE knows(FROM person TO person, weight DOUBLE);
COPY person from "TEST_RESOURCE/test/gopt/resources/person.csv";
COPY knows from "TEST_RESOURCE/test/gopt/resources/knows.csv"
MATCH (n:person) return n.name;
Match (n:person) Where n.id = 1 Return n;
Match (n:person)-[f:knows]->(m:person) Return n.name, f, m.name;
Match (n:person)-[f:knows]->(m:person) Where n.id = 1 AND f.weight > 10.0 Return n.name, f, m.name;
Match (n:person)-[f:knows]->(m:person) Where n.id = 1 AND f.weight > 10.0 AND m.name = 'cc' Return n.name, f.weight, m.name;
