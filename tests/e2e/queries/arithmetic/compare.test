-DATASET CSV tinysnb

--

-CASE CompareTest

-LOG EqualTo
-STATEMENT RETURN (1 = 1)
---- 1
True

-LOG EqualTo
-STATEMENT RETURN (1 = 2)
---- 1
False

-LOG NotEqualTo
-STATEMENT RETURN (1 <> 2)
---- 1
True

-LOG NotEqualTo
-STATEMENT RETURN (1 <> 1)
---- 1
False

-LOG LessThan
-STATEMENT RETURN (1 < 2)
---- 1
True

-LOG LessThan
-STATEMENT RETURN (1 < 1)
---- 1
False

-LOG LessThan
-STATEMENT RETURN (1 < 0)
---- 1
False

-LOG LessThanOrEqualTo
-STATEMENT RETURN (1 <= 2)
---- 1
True

-LOG LessThanOrEqualTo
-STATEMENT RETURN (1 <= 1)
---- 1
True

-LOG LessThanOrEqualTo
-STATEMENT RETURN (1 <= 0)
---- 1
False

-LOG GreaterThan
-STATEMENT RETURN (2 > 1)
---- 1
True

-LOG GreaterThan
-STATEMENT RETURN (1 > 1)
---- 1
False

-LOG GreaterThan
-STATEMENT RETURN (0 > 1)
---- 1
False

-LOG GreaterThanOrEqualTo
-STATEMENT RETURN (2 >= 1)
---- 1
True

-LOG GreaterThanOrEqualTo
-STATEMENT RETURN (1 >= 1)
---- 1
True

-LOG GreaterThanOrEqualTo
-STATEMENT RETURN (0 >= 1)
---- 1
False

