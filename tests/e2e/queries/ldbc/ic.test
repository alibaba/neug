-LOG IC3
# `WITH distinct otherP` is not supported
# use `WITH otherP, COUNT(otherP) as cnt` instead
-STATEMENT MATCH 
    (p:PERSON {id: 15393162790207})-[:KNOWS*1..3]-(otherP:PERSON)
WITH otherP, COUNT(otherP) as cnt
WHERE otherP.id <> 15393162790207
MATCH (country:PLACE)<-[:ISLOCATEDIN]-(message : POST : COMMENT)-[:HASCREATOR]->(otherP:PERSON)-[ISLOCATEDIN]->(city:PLACE)-[:ISPARTOF]-> (country2:PLACE)
WHERE 
     (country.name = "Puerto_Rico" OR country.name = "Republic_of_Macedonia")
      AND message.creationDate >= 1291161600000
      AND message.creationDate < 1293753600000
WITH 

     message,
    otherP, 
    country,country2
WHERE (country2.name <> "Puerto_Rico" AND country2.name <> "Republic_of_Macedonia")
    
WITH otherP,
     CASE WHEN country.name="Puerto_Rico" THEN 1 ELSE 0 END AS messageX,
     CASE WHEN country.name="Republic_of_Macedonia" THEN 1 ELSE 0 END AS messageY
WITH otherP, sum(messageX) AS xCount, sum(messageY) AS yCount
WHERE xCount > 0 AND yCount > 0
RETURN
    otherP.id as id,
    otherP.firstName as firstName,
    otherP.lastName as lastName,
    xCount,
    yCount,
    xCount + yCount as total 
ORDER BY total DESC, id ASC LIMIT 20;
---- 0


-LOG IC4
-STATEMENT MATCH (person:PERSON {id: 10995116278874})-[:KNOWS]-(friend:PERSON)<-[:HASCREATOR]-(post:POST)-[:HASTAG]->(tag: TAG)
WITH tag,
     CASE
       WHEN  post.creationDate >= 1338508800000 AND post.creationDate < 1340928000000 THEN 1
       ELSE 0
     END AS valid,
     CASE
       WHEN post.creationDate < 1338508800000  THEN 1
       ELSE 0
     END AS inValid
WITH tag, sum(valid) AS postCount, sum(inValid) AS inValidPostCount
WHERE postCount>0 AND inValidPostCount=0

RETURN tag.name AS tagName, postCount
ORDER BY postCount DESC, tagName ASC
LIMIT 10;
