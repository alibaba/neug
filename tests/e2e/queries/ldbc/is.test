-DATASET CSV ldbc

-CASE LDBCTest

-LOG IS1
-SKIP
-STATEMENT MATCH (n:PERSON {id: 26388279068220})-[:ISLOCATEDIN]->(p:PLACE)
RETURN
    n.firstName AS firstName,
    n.lastName AS lastName,
    n.birthday AS birthday,
    n.locationIP AS locationIp,
    n.browserUsed AS browserUsed,
    p.id AS cityId,
    n.gender AS gender,
    n.creationDate AS creationDate
---- 1
Jun|Wang|575424000000|1.12.242.179|Opera|507|female|1331161432355


-LOG IS2
# do not support [:REPLYOF*0..*], use [:REPLYOF*0..10] instead
-SKIP
-STATEMENT MATCH (p :PERSON {id: 26388279068220})<-[:HASCREATOR]-(message: POST : COMMENT)
WITH
 message,
 message.id AS messageId,
 message.creationDate AS messageCreationDate
ORDER BY messageCreationDate DESC, messageId ASC
LIMIT 10
MATCH (message: POST : COMMENT)-[:REPLYOF*0..10]->(post:POST)-[:HASCREATOR]->(person:PERSON)
RETURN
 messageId,
 CASE WHEN message.content = "" THEN message.imageFile 
 ELSE message.content END as messageContent,
 messageCreationDate,
 post.id AS originalPostId,
 person.id AS originalPostAuthorId,
 person.firstName AS originalPostAuthorFirstName,
 person.lastName AS originalPostAuthorLastName
ORDER BY messageCreationDate DESC, messageId ASC
