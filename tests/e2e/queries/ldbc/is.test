-STATEMENT MATCH (n:PERSON {id: 19791209300143 })-[r:KNOWS]-(friend:PERSON)
RETURN
    friend.id AS personId,
    friend.firstName AS firstName,
    friend.lastName AS lastName,
    r.creationDate AS friendshipCreationDate
