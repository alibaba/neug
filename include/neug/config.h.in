#pragma once

#include <string>

/**
 * @file config.h
 * @brief Build-time configuration macros for NeuG
 */

namespace gs {

enum class DBMode { READ_ONLY = 0, READ_WRITE = 1 };

struct NeugDBConfig {
  static constexpr const float DEFAULT_RESERVE_RATIO = 1.2;
  NeugDBConfig()
      : csr_reserve_ratio(DEFAULT_RESERVE_RATIO),
        mode(DBMode::READ_WRITE),
        planner_kind("gopt"),
        thread_num(1),
        warmup(false),
        enable_auto_compaction(false),
        memory_level(1),
        wal_uri("{GRAPH_DATA_DIR}/wal"),
        compact_csr(true),
        compact_on_close(true),
        checkpoint_on_close(false),
        checkpoint_after_recovery(false) {}
  NeugDBConfig(const std::string& data_dir_, int thread_num_ = 1)
      : csr_reserve_ratio(DEFAULT_RESERVE_RATIO),
        mode(DBMode::READ_WRITE),
        data_dir(data_dir_),
        planner_kind("gopt"),
        thread_num(thread_num_),
        warmup(false),
        enable_auto_compaction(false),
        memory_level(1),
        wal_uri("{GRAPH_DATA_DIR}/wal"),
        compact_csr(true),
        compact_on_close(true),
        checkpoint_on_close(false),
        checkpoint_after_recovery(false) {}

  float csr_reserve_ratio;
  DBMode mode;
  std::string data_dir;
  std::string planner_kind;  // currently only gopt
  int thread_num;
  bool warmup;
  bool enable_auto_compaction;

  /*
    0 - sync with disk;
    1 - mmap virtual memory;
    2 - preferring hugepages;
    3 - force hugepages;
  */
  int memory_level;
  std::string wal_uri;  // Indicate the where shall we store the wal files.
  // could be file://{GRAPH_DATA_DIR}/wal or other scheme
  // that interactive supports
  bool compact_csr;          // whether compact the csr when doing compaction.
  bool compact_on_close;     // whether compact the graph when closing the graph
                             // db.
  bool checkpoint_on_close;  // whether dump the graph when
  // closing the graph db.
  bool checkpoint_after_recovery;  // whether create a checkpoint after recovery
                                   // from wal.
};

}  // namespace gs

// Other build configuration options can be added here
#cmakedefine BUILD_WITH_OSS
